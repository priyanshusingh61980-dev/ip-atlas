{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev",
      "type": "shell",
      "command": "pnpm dev",
      "isBackground": true,
      "problemMatcher": []
    },
    { "label": "build", "type": "shell", "command": "pnpm build", "problemMatcher": ["$tsc"] },
    {
      "label": "lint",
      "type": "shell",
      "command": "pnpm lint",
      "problemMatcher": ["$eslint-stylish"]
    },
    {
      "label": "typecheck",
      "type": "shell",
      "command": "pnpm typecheck",
      "problemMatcher": ["$tsc"]
    },
    { "label": "test", "type": "shell", "command": "pnpm test", "problemMatcher": [] },
    { "label": "test:e2e", "type": "shell", "command": "pnpm test:e2e", "problemMatcher": [] },
    {
      "label": "validate",
      "dependsOrder": "sequence",
      "dependsOn": ["lint", "typecheck", "test", "build"],
      "problemMatcher": []
    }
  ]
}
